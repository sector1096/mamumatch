# API/Auth
APP_ENV=dev
APP_API_KEY=change-me

# MariaDB existente
APP_DB_HOST=127.0.0.1
APP_DB_PORT=3306
APP_DB_USER=root
APP_DB_PASSWORD=change-me
APP_DB_NAME=mamutero

# Queue
APP_REDIS_URL=redis://redis:6379/0
APP_RQ_QUEUE=mamutero

# Storage
APP_VIDEOS_DIR=/data/videos
APP_WHISPER_DIR=/data/whisper
APP_LOGS_DIR=/data/logs/jobs

# Whisper
APP_WHISPER_MODEL=large
APP_WHISPER_DEVICE=cpu
APP_WHISPER_LANGUAGE_DEFAULT=es

# Binaries
APP_YT_DLP_PATH=yt-dlp
APP_FFMPEG_PATH=ffmpeg

# Video finder
APP_YOUTUBE_API_KEY=

# Frontend -> API
# Opcional. Si se deja vacio, el frontend usa http(s)://<host-actual>:8001
VITE_API_URL=
VITE_API_KEY=change-me
